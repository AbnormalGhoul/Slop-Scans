{
  "manifest_version": 3,
  "name": "Slop Scan",
  "description": "Scan for slop content",
  "version": "0.0.1",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "/popup.html",
    "default_title": "Slop Scan"
  },
  "background": {
    "service_worker": "/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["/content.js"],
      "run_at": "document_start"
    }
  ]
}
